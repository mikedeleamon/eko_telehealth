# Dependencies
node_modules/

# Expo
.expo/
.expo-shared/
dist/
web-build/

# Native builds — ios/ (and android/, once prebuilt) each get their own
# .gitignore from `expo prebuild` for Pods/, build/, xcuserdata, etc.
*.orig.*

# Metro
.metro-health-check*

# TypeScript
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing / coverage
coverage/

# dotenv environment variable files — never commit real secrets
.env
.env.*
!.env.example

# Signing credentials — EAS/Xcode/Android may write these locally
credentials.json
*.p8
*.p12
*.key
*.mobileprovision
*.jks
*.keystore

# macOS
.DS_Store

# Editors
.vscode/
.idea/

# Yarn Integrity file
.yarn-integrity
