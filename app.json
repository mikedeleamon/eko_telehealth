{
  "expo": {
    "name": "Eko Telehealth",
    "slug": "eko-telehealth",
    "scheme": "ekotelehealth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ekotelehealth.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Eko Telehealth uses your camera for video visits with your doctor.",
        "NSMicrophoneUsageDescription": "Eko Telehealth uses your microphone for audio and video visits with your doctor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1565C0"
      },
      "package": "com.ekotelehealth.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@stream-io/video-react-native-sdk"
    ]
  }
}
