# Eko Telehealth — mobile app environment
# Copy to .env and fill in real values. Every EXPO_PUBLIC_* var is inlined into
# the JS bundle at build time, so ONLY public values belong here — never a
# secret (the Stream secret, payment keys, etc. live on the backend).
#
# Defaults below run the app fully on in-app mock data — no backend, no keys.
# To go live, see the "Going live" block at the bottom.

# Base URL of the Eko Telehealth backend API (Railway). Leave empty to use the
# in-app mock data (default for development/demos).
EXPO_PUBLIC_API_URL=

# Force mock data even when an API URL is set (true | false).
EXPO_PUBLIC_USE_MOCK_API=true

# Realtime provider for chat + video/audio calls: mock | stream
EXPO_PUBLIC_REALTIME_PROVIDER=mock

# Public Stream API key (getstream.io → your app). Safe to ship — the secret
# stays on the backend. Required when EXPO_PUBLIC_REALTIME_PROVIDER=stream.
EXPO_PUBLIC_STREAM_API_KEY=

# ── Going live ──────────────────────────────────────────────────────────────
# Point at the deployed backend and flip mock off:
#   EXPO_PUBLIC_API_URL=https://<your-app>.up.railway.app
#   EXPO_PUBLIC_USE_MOCK_API=false
# Turn on Stream chat + calls (chat works immediately; video needs a dev-client
# rebuild — npx expo prebuild -p ios --clean && npm run ios):
#   EXPO_PUBLIC_REALTIME_PROVIDER=stream
#   EXPO_PUBLIC_STREAM_API_KEY=<public key from getstream.io>
