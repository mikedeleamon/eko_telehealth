# Eko Telehealth — mobile app environment
# Copy to .env and fill in real values. All EXPO_PUBLIC_* vars are inlined
# into the JS bundle at build time — never put secrets in them.

# Base URL of the Eko Telehealth backend API. Leave empty to run fully
# on the in-app mock data (default for development/demos).
EXPO_PUBLIC_API_URL=

# Force mock data even when an API URL is set (true/false).
EXPO_PUBLIC_USE_MOCK_API=true

# Realtime provider for chat + video/audio calls: mock | twilio
EXPO_PUBLIC_REALTIME_PROVIDER=mock
